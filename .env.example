# ── Video Discovery runtime configuration ────────────────────────────────────
# Copy to .env and populate for local development (never commit .env)

# Azure Key Vault that holds `youtube-api-key`
MIMESIS_KEY_VAULT_URL=https://<vault-name>.vault.azure.net/

# Primary table endpoint of the Storage Account
MIMESIS_STORAGE_ACCOUNT_URL=https://<account-name>.table.core.windows.net/

# Name of the Azure Table used as the Discovery Ledger (auto-created by Terraform)
MIMESIS_DISCOVERY_LEDGER_TABLE=discoveryLedger

# Fully-qualified Service Bus hostname (no https://)
MIMESIS_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# Name of the Service Bus queue that receives VideoDiscovered events
MIMESIS_SERVICE_BUS_QUEUE=sb-queue-video-discovered

# Application Insights connection string (from Terraform output)
MIMESIS_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Optional ceiling for search results (default: 500)
MIMESIS_DEFAULT_MAX_RESULTS=500
